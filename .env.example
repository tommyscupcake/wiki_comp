# ==========================================
# ENTERPRISE WIKI - ENVIRONMENT VARIABLES
# ==========================================
# INSTRUCTIONS: Copy this file, rename it to .env.local,
# and fill in the values below. NEVER commit .env.local to Git.

# --- DATABASE (RDS Postgres in production) ---
# postgresql://<user>:<password>@<host>:5432/<database>
DATABASE_URL=postgresql://your_user:your_password@127.0.0.1:5432/enterprise_wiki
# RDS requires SSL by default. Set to "disable" only for local Postgres without SSL.
DATABASE_SSL=require

# --- DATABASE ROUTER ---
# Controls whether app data (users, teams) is read from the local database.json
# file ('local') or from the real Postgres database ('live').
NEXT_PUBLIC_API_MODE=local

# --- FILE STORAGE ---
# Controls where uploaded files (images, attachments) are saved.
# 'local' writes to public/uploads (dev only). 's3' uploads to AWS S3.
STORAGE_MODE=local

# --- AWS S3 (IAM ROLE AUTHENTICATED) ---
# Do not set AWS access keys here. On EC2, the SDK uses the instance's IAM role.
S3_BUCKET_NAME=your_bucket_name_here
AWS_REGION=eu-central-1

# --- GOOGLE GEMINI API ---
GEMINI_API_KEY=your_gemini_api_key_here
